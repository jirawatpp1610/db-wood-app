# =========================================================
# .streamlit/secrets.toml  —  TEMPLATE (อย่า commit ไฟล์จริง!)
# =========================================================

[auth]
# รหัสผ่านสำหรับเข้าใช้งาน dashboard
password = "your_password_here"

[supabase]
# Project URL — ดูได้ที่ Project Settings → API
url = "https://xxxxxxxxxxxx.supabase.co"

# ⚠️ ใช้ service_role key เท่านั้น (ไม่ใช่ anon key)
# ดูได้ที่ Project Settings → API → "service_role" (secret)
# ห้าม expose key นี้ฝั่ง client เด็ดขาด — เก็บใน Secrets เท่านั้น
service_role_key = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx"

# ชื่อ Storage Bucket
bucket = "master-data"
